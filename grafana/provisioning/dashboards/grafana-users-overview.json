{
  "uid": "frontend-users-overview",
  "title": "Frontend - All Users Overview",
  "tags": ["frontend", "users-overview"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Active Users",
      "description": "Distinct users who performed any action in the selected time window",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "count(sum by (user_username) (increase(microservices_frontend_button_clicks_total[$__range])) > 0) or count(sum by (user_username) (increase(microservices_frontend_tab_switches_total[$__range])) > 0)",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "displayName": "Active Users",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 2,
      "title": "Users Who Reached Checkout",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "count(sum by (user_username) (increase(microservices_frontend_form_submits_total{form_name=\"checkout\"}[$__range])) > 0)",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "displayName": "Reached Checkout",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 3,
      "title": "Users Who Only Browsed",
      "description": "Had tab switches but no form submits — never converted",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "count(sum by (user_username) (increase(microservices_frontend_tab_switches_total[$__range])) > 0) - count(sum by (user_username) (increase(microservices_frontend_form_submits_total[$__range])) > 0)",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "displayName": "Browsers (no action)",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "orange", "value": null }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 4,
      "title": "Total Actions",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(microservices_frontend_button_clicks_total[$__range])) + sum(increase(microservices_frontend_form_submits_total[$__range]))",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "displayName": "Total Actions",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "purple", "value": null }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 5,
      "title": "Most Active Users",
      "description": "Ranked by total actions (clicks + form submits)",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": { "orientation": "horizontal" },
      "targets": [
        {
          "expr": "sort_desc(sum by (user_username) (increase(microservices_frontend_button_clicks_total[$__range])) + sum by (user_username) (increase(microservices_frontend_form_submits_total[$__range])))",
          "legendFormat": "{{ user_username }}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 80 } }
      }
    },
    {
      "id": 6,
      "title": "Most Time in App",
      "description": "Total time spent across all tabs per user",
      "type": "barchart",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": { "orientation": "horizontal" },
      "targets": [
        {
          "expr": "sort_desc(sum by (user_username) (increase(microservices_frontend_tab_time_spent_ms_sum[$__range])))",
          "legendFormat": "{{ user_username }}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "fillOpacity": 80 }
        }
      }
    },
    {
      "id": 7,
      "title": "User Activity Over Time",
      "description": "Activity rate per user — spot when each user was active",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (user_username) (rate(microservices_frontend_button_clicks_total[$__rate_interval]) + rate(microservices_frontend_tab_switches_total[$__rate_interval]))",
          "legendFormat": "{{ user_username }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 8,
      "title": "User Journey Summary",
      "description": "Per user: clicks, form submits, tab switches, avg time per tab, reached checkout",
      "type": "table",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 10 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (user_username, user_role) (increase(microservices_frontend_button_clicks_total[$__range]))",
          "legendFormat": "",
          "instant": true,
          "format": "table",
          "refId": "A"
        },
        {
          "expr": "sum by (user_username, user_role) (increase(microservices_frontend_form_submits_total[$__range]))",
          "legendFormat": "",
          "instant": true,
          "format": "table",
          "refId": "B"
        },
        {
          "expr": "sum by (user_username, user_role) (increase(microservices_frontend_tab_switches_total[$__range]))",
          "legendFormat": "",
          "instant": true,
          "format": "table",
          "refId": "C"
        },
        {
          "expr": "sum by (user_username) (increase(microservices_frontend_tab_time_spent_ms_sum[$__range])) / sum by (user_username) (increase(microservices_frontend_tab_time_spent_ms_count[$__range]))",
          "legendFormat": "",
          "instant": true,
          "format": "table",
          "refId": "D"
        },
        {
          "expr": "sum by (user_username) (increase(microservices_frontend_form_submits_total{form_name=\"checkout\"}[$__range]))",
          "legendFormat": "",
          "instant": true,
          "format": "table",
          "refId": "E"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "user_username": "User",
              "user_role": "Role",
              "Value #A": "Clicks",
              "Value #B": "Form Submits",
              "Value #C": "Tab Switches",
              "Value #D": "Avg Tab Time (ms)",
              "Value #E": "Checkout Submits"
            },
            "excludeByName": { "Time": true }
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Avg Tab Time (ms)" },
            "properties": [{ "id": "unit", "value": "ms" }]
          },
          {
            "matcher": { "id": "byName", "options": "Checkout Submits" },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "green", "value": 1 }
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 9,
      "title": "What Each User Clicked",
      "type": "table",
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sort_desc(sum by (user_username, ctx_buttonId) (increase(microservices_frontend_button_clicks_total[$__range])))",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "user_username": "User",
              "ctx_buttonId": "Button",
              "Value": "Clicks"
            },
            "excludeByName": { "Time": true }
          }
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Datasource"
      }
    ]
  }
}
