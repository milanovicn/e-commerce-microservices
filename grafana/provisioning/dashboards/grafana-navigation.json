{
  "uid": "frontend-navigation",
  "title": "Frontend - Navigation & Tab Switching",
  "tags": ["frontend", "navigation"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Tab Switches Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (tab_to) (rate(microservices_frontend_tab_switches_total[$__rate_interval]))",
          "legendFormat": "→ {{ tab_to }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 2,
      "title": "Most Visited Tabs / Routes",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sort_desc(sum by (tab_to) (increase(microservices_frontend_tab_switches_total[$__range])))",
          "legendFormat": "{{ tab_to }}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 80 }
        }
      }
    },
    {
      "id": 3,
      "title": "Navigation Paths (from → to)",
      "type": "table",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sort_desc(sum by (tab_from, tab_to) (increase(microservices_frontend_tab_switches_total[$__range])))",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "organize", "options": {
          "renameByName": {
            "tab_from": "From",
            "tab_to": "To",
            "Value": "Count"
          },
          "excludeByName": {
            "Time": true
          }
        }}
      ]
    },
    {
      "id": 4,
      "title": "Average Time Spent per Tab (ms)",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (tab_name) (increase(microservices_frontend_tab_time_spent_ms_sum[$__range])) / sum by (tab_name) (increase(microservices_frontend_tab_time_spent_ms_count[$__range]))",
          "legendFormat": "{{ tab_name }}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "fillOpacity": 80 }
        }
      }
    },
    {
      "id": 5,
      "title": "Total Time Spent per Tab (ms)",
      "type": "barchart",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (tab_name) (increase(microservices_frontend_tab_time_spent_ms_sum[$__range]))",
          "legendFormat": "{{ tab_name }}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "fillOpacity": 80 }
        }
      }
    },
    {
      "id": 6,
      "title": "Time Spent per Tab per User",
      "type": "table",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sort_desc(sum by (user_username, user_role, tab_name) (increase(microservices_frontend_tab_time_spent_ms_sum[$__range])) / sum by (user_username, user_role, tab_name) (increase(microservices_frontend_tab_time_spent_ms_count[$__range])))",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "organize", "options": {
          "renameByName": {
            "user_username": "User",
            "user_role": "Role",
            "tab_name": "Tab",
            "Value": "Avg Time (ms)"
          },
          "excludeByName": {
            "Time": true
          }
        }}
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    },
    {
      "id": 7,
      "title": "Tab Switch Heatmap by Hour",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (user_username) (rate(microservices_frontend_tab_switches_total[$__rate_interval]))",
          "legendFormat": "{{ user_username }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 8,
      "title": "Navigation per User",
      "type": "table",
      "gridPos": { "x": 0, "y": 40, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sort_desc(sum by (user_username, user_role, tab_from, tab_to) (increase(microservices_frontend_tab_switches_total[$__range])))",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "organize", "options": {
          "renameByName": {
            "user_username": "User",
            "user_role": "Role",
            "tab_from": "From",
            "tab_to": "To",
            "Value": "Count"
          },
          "excludeByName": {
            "Time": true
          }
        }}
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Datasource"
      },
      {
        "name": "user",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(microservices_frontend_tab_switches_total, user_username)",
        "label": "User",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2
      }
    ]
  }
}
