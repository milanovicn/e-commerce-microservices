{
  "uid": "frontend-user-story",
  "title": "Frontend - User Story",
  "tags": ["frontend", "user-story"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total Clicks",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(microservices_frontend_button_clicks_total{user_username=~\"$user\"}[$__range]))",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "displayName": "Button Clicks",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 2,
      "title": "Total Form Submits",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(microservices_frontend_form_submits_total{user_username=~\"$user\"}[$__range]))",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "displayName": "Form Submits",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 3,
      "title": "Total Tab Switches",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(microservices_frontend_tab_switches_total{user_username=~\"$user\"}[$__range]))",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "displayName": "Tab Switches",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "orange", "value": null }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 4,
      "title": "Reached Checkout",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(microservices_frontend_form_submits_total{user_username=~\"$user\", form_name=\"checkout\"}[$__range])) or vector(0)",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "displayName": "Checkout Submits",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 5,
      "title": "Activity Over Time",
      "description": "How active was this user across the selected time window",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(microservices_frontend_button_clicks_total{user_username=~\"$user\"}[$__rate_interval]))",
          "legendFormat": "Button Clicks"
        },
        {
          "expr": "sum(rate(microservices_frontend_form_submits_total{user_username=~\"$user\"}[$__rate_interval]))",
          "legendFormat": "Form Submits"
        },
        {
          "expr": "sum(rate(microservices_frontend_tab_switches_total{user_username=~\"$user\"}[$__rate_interval]))",
          "legendFormat": "Tab Switches"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 6,
      "title": "Time Spent per Tab",
      "description": "Where did this user focus their attention",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "orientation": "horizontal",
        "xField": "tab_name"
      },
      "targets": [
        {
          "expr": "sort_desc(sum by (tab_name) (increase(microservices_frontend_tab_time_spent_ms_sum{user_username=~\"$user\"}[$__range])) / sum by (tab_name) (increase(microservices_frontend_tab_time_spent_ms_count{user_username=~\"$user\"}[$__range])))",
          "legendFormat": "{{ tab_name }}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "fillOpacity": 80 }
        }
      }
    },
    {
      "id": 7,
      "title": "Tabs Visited",
      "description": "How many times each tab was visited",
      "type": "barchart",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "orientation": "horizontal"
      },
      "targets": [
        {
          "expr": "sort_desc(sum by (tab_to) (increase(microservices_frontend_tab_switches_total{user_username=~\"$user\"}[$__range])))",
          "legendFormat": "{{ tab_to }}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 80 }
        }
      }
    },
    {
      "id": 8,
      "title": "Buttons Clicked",
      "description": "Which buttons this user interacted with",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "orientation": "horizontal"
      },
      "targets": [
        {
          "expr": "sort_desc(sum by (ctx_buttonId) (increase(microservices_frontend_button_clicks_total{user_username=~\"$user\"}[$__range])))",
          "legendFormat": "{{ ctx_buttonId }}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 80 }
        }
      }
    },
    {
      "id": 9,
      "title": "Forms Submitted",
      "description": "Which forms this user submitted",
      "type": "barchart",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "orientation": "horizontal"
      },
      "targets": [
        {
          "expr": "sort_desc(sum by (form_name) (increase(microservices_frontend_form_submits_total{user_username=~\"$user\"}[$__range])))",
          "legendFormat": "{{ form_name }}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 80 }
        }
      }
    },
    {
      "id": 10,
      "title": "Navigation Path",
      "description": "Which tab transitions this user made",
      "type": "table",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sort_desc(sum by (tab_from, tab_to) (increase(microservices_frontend_tab_switches_total{user_username=~\"$user\"}[$__range])))",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "tab_from": "From",
              "tab_to": "To",
              "Value": "Times"
            },
            "excludeByName": { "Time": true }
          }
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Datasource"
      },
      {
        "name": "user",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(microservices_frontend_tab_switches_total, user_username)",
        "label": "User",
        "includeAll": false,
        "multi": false,
        "refresh": 2
      }
    ]
  }
}
