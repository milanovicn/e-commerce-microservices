    {
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "description": "How many unique users reached each stage of the purchase journey",
      "fieldConfig": {
        "defaults": {
          "fieldMinMax": false
        },
        "overrides": []
      },
      "gridPos": {
        "h": 17,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "id": 5,
      "options": {
        "baidu": {
          "callback": "bmapReady",
          "key": ""
        },
        "code": {
          "language": "javascript",
          "showLineNumbers": false,
          "showMiniMap": false
        },
        "editor": {
          "format": "auto"
        },
        "editorMode": "code",
        "gaode": {
          "key": "",
          "plugin": "AMap.Scale,AMap.ToolBar"
        },
        "getOption": "const series = context.panel.data.series;\n\nconst getValue = (refId) => {\n  const s = series.find(s => s.refId === refId);\n  if (!s || !s.fields) return 0;\n  const f = s.fields.find(f => f.name === 'Value');\n  return f ? Math.round(f.values[f.values.length - 1] || 0) : 0;\n};\n\nconst browsed = getValue('A');\nconst addedToCart = getValue('B');\nconst checkedOut = getValue('C');\nconst viewedNotification = getValue('D');\n\nconst droppedAtCart = Math.max(0, browsed - addedToCart);\nconst droppedAtCheckout = Math.max(0, addedToCart - checkedOut);\nconst droppedAfterCheckout = Math.max(0, checkedOut - viewedNotification);\n\n// Build links only if values are meaningful\nconst links = [];\nif (addedToCart > 0) links.push({ source: 'Browsed Products', target: 'Added to Cart', value: addedToCart });\nif (droppedAtCart > 0) links.push({ source: 'Browsed Products', target: 'Dropped Off', value: droppedAtCart });\nif (checkedOut > 0) links.push({ source: 'Added to Cart', target: 'Completed Checkout', value: checkedOut });\nif (droppedAtCheckout > 0) links.push({ source: 'Added to Cart', target: 'Abandoned Cart', value: droppedAtCheckout });\nif (viewedNotification > 0) links.push({ source: 'Completed Checkout', target: 'Viewed Notification', value: viewedNotification });\n\nreturn {\n  tooltip: { trigger: 'item', triggerOn: 'mousemove' },\n  series: [\n    {\n      type: 'sankey',\n      layout: 'none',\n      emphasis: { focus: 'adjacency' },\n      nodeWidth: 20,\n      nodeGap: 50,\n      data: [\n        { name: 'Browsed Products' },\n        { name: 'Added to Cart' },\n        { name: 'Completed Checkout' },\n        { name: 'Viewed Notification' },\n        { name: 'Abandoned Cart' },\n        { name: 'Dropped Off' }\n\n      ],\n      links: links,\n      label: {\n        color: '#000000',\n        fontSize: 13,\n        textStyle: { color: '#000000' }\n      },\n      lineStyle: { color: 'gradient', opacity: 0.4 }\n    }\n  ]\n};",
        "google": {
          "callback": "gmapReady",
          "key": ""
        },
        "map": "none",
        "renderer": "canvas",
        "themeEditor": {
          "config": "{}",
          "name": "default"
        },
        "visualEditor": {
          "code": "return {\n  dataset: context.editor.dataset,\n  series: context.editor.series,\n  xAxis: {\n    type: 'time',\n  },\n  yAxis: {\n    type: 'value',\n    min: 'dataMin',\n  },\n}\n",
          "dataset": [],
          "series": []
        }
      },
      "pluginVersion": "7.2.2",
